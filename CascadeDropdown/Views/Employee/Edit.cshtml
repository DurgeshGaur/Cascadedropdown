@model Employee

<form asp-controller="Employee" asp-action="Edit" method="post">
    <div class="row">
        <div class="col-4">
            <label>Name</label>
            <input asp-for="Name" class="form-control" />
        </div>

        <div class="col-4">
            <label>DOB</label>
            <input type="date" asp-for="DateTime" class="form-control" />
        </div>

        <div class="col-4">
            <label>Email</label>
            <input type="email" asp-for="Email" class="form-control" />
        </div>

        <div class="col-4">
            <label>Country</label>
            <select asp-for="CountryId" id="CountryId" class="form-select" asp-items="@ViewBag.Country">
                <option value="">Select</option>
            </select>
        </div>

        <div class="col-4">
            <label>State</label>
            <select asp-for="StateId" id="StateId" class="form-select">
                <option value="">Select</option>
            </select>
        </div>

        <div class="col-4">
            <label>City</label>
            <select asp-for="CityId" id="CityId" class="form-select">
                <option value="">Select</option>
            </select>
        </div>
    </div>

    <div class="mt-3">
        <button type="submit" class="btn btn-success">Save</button>
    </div>
</form>
<script src="~/lib/jquery/dist/jquery.min.js"></script>

<script>
    $(document).ready(function () {

        // Read existing values (for Edit mode)
        var selectedCountryId = '@Model.CountryId';
        var selectedStateId = '@Model.StateId';
        var selectedCityId = '@Model.CityId';

        // Load states and cities initially (only for Edit mode)
        if (selectedCountryId) {
            loadStates(selectedCountryId, selectedStateId, selectedCityId);
        }

        // Country → Load States
        $("#CountryId").change(function () {
            var countryId = $(this).val();
            $("#CityId").empty().append('<option value="">Select</option>');
            if (countryId) {
                loadStates(countryId);
            } else {
                $("#StateId").empty().append('<option value="">Select</option>');
            }
        });

        // State → Load Cities
        $("#StateId").change(function () {
            var stateId = $(this).val();
            if (stateId) {
                loadCities(stateId);
            } else {
                $("#CityId").empty().append('<option value="">Select</option>');
            }
        });

        // 🔹 Reusable Method: Load States
        function loadStates(countryId, selectedStateId = null, selectedCityId = null) {
            $.ajax({
                url: '/City/GetState',
                type: 'GET',
                data: { countryId: countryId },
                success: function (data) {
                    var $state = $("#StateId");
                    $state.empty().append('<option value="">Select</option>');
                    $.each(data, function (i, state) {
                        var selected = (state.id == selectedStateId) ? "selected" : "";
                        $state.append('<option value="' + state.id + '" ' + selected + '>' + state.name + '</option>');
                    });

                    // If editing, load cities after states are bound
                    if (selectedStateId && selectedCityId) {
                        loadCities(selectedStateId, selectedCityId);
                    }
                },
                error: function () {
                    alert("Error loading states");
                }
            });
        }

        // 🔹 Reusable Method: Load Cities
        function loadCities(stateId, selectedCityId = null) {
            $.ajax({
                url: '/Employee/GetCity',
                type: 'GET',
                data: { stateId: stateId },
                success: function (data) {
                    var $city = $("#CityId");
                    $city.empty().append('<option value="">Select</option>');
                    $.each(data, function (i, city) {
                        var selected = (city.id == selectedCityId) ? "selected" : "";
                        $city.append('<option value="' + city.id + '" ' + selected + '>' + city.name + '</option>');
                    });
                },
                error: function () {
                    alert("Error loading cities");
                }
            });
        }
    });
</script>