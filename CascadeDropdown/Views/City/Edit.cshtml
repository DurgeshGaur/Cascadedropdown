@model City

<form asp-controller="City" asp-action="Edit" method="post">
    <input type="hidden" asp-for="Id" />
    <div class="row">
        <div class="col-4">
            <label>Country</label>
            <select asp-for="CountryId" id="CountryId" class="form-select" asp-items="@ViewBag.Country">

                <option value="">select</option>
            </select>
        </div>
        <div class="col-4">
            <label>State</label>
            <select asp-for="StateId" id="StateId" class="form-select">

                <option value="">select</option>
            </select>
        </div>
        <div class="col-4">
            <label>Name</label>
            <input asp-for="Name" class="form-control" />
        </div>
    </div>
    <div>
        <button type="submit" class="btn btn-success">Save</button>
    </div>
</form>
