        var countryId = '@Model.CountryId';
        var stateId = '@Model.StateId';
        debugger;
        loadStates("CountryId", "StateId", stateId);

        // When user changes country, reload state list
        $("#CountryId").change(function () {
            loadStates("CountryId", "StateId");
        });
        function loadStates(countrySelectorId, stateSelectorId, selectedStateId = null) {
            debugger;
            var countryId = $("#" + countrySelectorId).val();
            var $state = $("#" + stateSelectorId);

            if (countryId) {
                $.ajax({
                    url: '/City/GetState',
                    type: 'GET',
                    data: { countryId: countryId },
                    success: function (data) {
                        $state.empty();
                        $state.append('<option value="">Select</option>');
                        $.each(data, function (i, state) {
                            var selected = (selectedStateId && state.id == selectedStateId) ? "selected" : "";
                            $state.append('<option value="' + state.id + '" ' + selected + '>' + state.name + '</option>');
                        });
                    },
                    error: function () {
                        alert("Error loading states");
                    }
                });
            } else {
                $state.empty();
                $state.append('<option value="">Select</option>');
            }
        }
    })
</script>